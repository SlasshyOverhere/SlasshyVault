# Google Drive OAuth Configuration
# GDRIVE_CLIENT_ID=...
# GDRIVE_CLIENT_SECRET=...

# OAuth Callback URL (Production)
# This is where Google redirects after authentication in production build.
# The callback page at this URL must redirect to slasshyvault://oauth?code=...
# For development (tauri dev), this is ignored and http://localhost:8085/callback is used automatically.
GDRIVE_REDIRECT_URI=https://indexer-oauth-callback.vercel.app/

# Sentry DSN for Rust/Tauri backend crash reporting.
# Create a project in Sentry and paste the DSN here.
# If unset, no crash reporting will be initialized.
# SENTRY_DSN=https://xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx@oXXXXXX.ingest.sentry.io/XXXXXX
