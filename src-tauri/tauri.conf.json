{
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devPath": "http://localhost:3000",
    "distDir": "../dist",
    "withGlobalTauri": false
  },
  "package": {
    "productName": "SlasshyVault",
    "version": "3.0.47"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "dialog": {
        "all": false,
        "open": true,
        "save": false
      },
      "protocol": {
        "asset": true,
        "assetScope": [
          "$APPDATA/**",
          "$RESOURCE/**"
        ]
      },
      "fs": {
        "all": false,
        "readFile": true,
        "writeFile": true,
        "readDir": true,
        "createDir": true,
        "removeFile": true,
        "renameFile": true,
        "exists": true,
        "scope": [
          "$APPDATA/**",
          "$RESOURCE/**",
          "$HOME/**"
        ]
      },
      "http": {
        "all": false,
        "request": true,
        "scope": [
          "https://api.themoviedb.org/**",
          "https://www.googleapis.com/**",
          "https://slasshyvault.onrender.com/**",
          "http://localhost:3000/**",
          "http://127.0.0.1:3000/**"
        ]
      },
      "shell": {
        "all": false,
        "open": true
      },
      "window": {
        "all": true
      }
    },
    "bundle": {
      "active": true,
      "category": "DeveloperTool",
      "copyright": "Copyright (c) 2026 Suman Patgiri",
      "deb": {
        "depends": []
      },
      "externalBin": [],
      "icon": [
        "icons/slasshyvault.png",
        "icons/slasshyvault.ico"
      ],
      "identifier": "com.slasshyvault.app",
      "longDescription": "",
      "macOS": {
        "entitlements": null,
        "exceptionDomain": "",
        "frameworks": [],
        "providerShortName": null,
        "signingIdentity": null
      },
      "resources": [],
      "shortDescription": "",
      "targets": "all",
      "windows": {
        "certificateThumbprint": null,
        "digestAlgorithm": "sha256",
        "timestampUrl": ""
      }
    },
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: https: data:; media-src 'self' asset: blob: https: http://localhost:* http://127.0.0.1:*; style-src 'self'; script-src 'self'; connect-src 'self' https://api.themoviedb.org https://www.googleapis.com https://slasshyvault.onrender.com ws://slasshyvault.onrender.com wss://slasshyvault.onrender.com http://localhost:* http://127.0.0.1:*; base-uri 'self'; form-action 'self'; frame-ancestors 'self'"
    },
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/SlasshyOverhere/SlasshyVault/releases/latest/download/latest.json"
      ],
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDRDQ0I5Mjk5NjFBQjU5MzEKUldReFdhdGhtWkxMVENNT1FNbWhZT0VUVmlJaEREdkR2akRGdFhFVDFHRWZIMnlUQ0JQSUtPN0UK"
    },
    "systemTray": {
      "iconPath": "icons/slasshyvault.ico",
      "iconAsTemplate": false,
      "menuOnLeftClick": false
    },
    "windows": [
      {
        "center": true,
        "label": "main",
        "fullscreen": false,
        "height": 900,
        "resizable": true,
        "title": "SlasshyVault",
        "width": 1400,
        "maximizable": true,
        "minWidth": 900,
        "minHeight": 600,
        "transparent": true,
        "decorations": false
      }
    ]
  }
}
